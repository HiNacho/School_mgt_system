datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model School {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // E.g., "greenwood-secondary" or "lagos-excel-primary"
  logoUrl     String?
  address     String?
  phone       String?
  email       String?
  gradingType String   @default("SECONDARY") // PRIMARY or SECONDARY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptionPlan    String    @default("Basic") // Basic, Standard, Premium
  subscriptionStatus  String    @default("trial") // active, trial, expired, suspended, archived
  subscriptionStart   DateTime?
  subscriptionEnd     DateTime?
  gracePeriodEnd      DateTime?

  payments            Payment[]
  usageLogs           UsageLog[]


  users              User[]
  students           Student[]
  classes            Class[]
  arms               Arm[]
  subjects           Subject[]
  sessions           AcademicSession[]
  terms              Term[]
  gradingRules       GradingRule[]
  scores             Score[]
  reportComments     ReportCardComment[]
  attendance         Attendance[]
  dailyAttendance    DailyAttendance[]
  messages           Message[]
  subjectAssignments SubjectAssignment[]
  scoreSubmissions   ScoreSubmission[]
  notifications      Notification[]
  parents            Parent[]

  events             Event[]
  classReportStatuses ClassReportStatus[]
  announcements      Announcement[]
}

model User {
  id           String   @id @default(uuid())
  schoolId     String?
  username     String   @unique
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  title        String?
  role         String // SUPER_ADMIN, SCHOOL_ADMIN, HEAD_TEACHER, CLASS_TEACHER, SUBJECT_TEACHER
  phone        String?
  passportPhoto String?
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  isActive     Boolean  @default(true)
  isFirstLogin Boolean  @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school             School?             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classTeacherArms   Arm[]               @relation("ClassTeacher")
  subjectAssignments SubjectAssignment[]
  scoresEntered      Score[]             @relation("ScoreTeacher")
  scoreSubmissions   ScoreSubmission[]
  notifications      Notification[]
  sentMessages       Message[]           @relation("MessageSender")
  receivedMessages   MessageRecipient[]  @relation("MessageRecipientUser")
  studentId          String?             @unique
  student            Student?            @relation("StudentUser", fields: [studentId], references: [id], onDelete: Cascade)
  parentId           String?             @unique
  parent             Parent?             @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  loginAuditLogs     LoginAuditLog[]
}

model LoginAuditLog {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginTime  DateTime  @default(now())
  logoutTime DateTime?
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime  @default(now())
}

model LoginAttempt {
  id              String   @id @default(uuid())
  ipAddress       String
  usernameOrEmail String
  attemptTime     DateTime @default(now())
  isSuccess       Boolean
}

model AcademicSession {
  id        String   @id @default(uuid())
  schoolId  String
  name      String // E.g., "2025/2026"
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms  Term[]
}

model Term {
  id        String   @id @default(uuid())
  schoolId  String
  sessionId String
  name      String // E.g., "First Term", "Second Term", "Third Term"
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  school  School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  scores             Score[]
  reportComments     ReportCardComment[]
  attendance         Attendance[]
  dailyAttendance    DailyAttendance[]
  subjectAssignments SubjectAssignment[]
  scoreSubmissions   ScoreSubmission[]
  classReportStatuses ClassReportStatus[]
}

model Class {
  id        String   @id @default(uuid())
  schoolId  String
  name      String // E.g., "JSS 1", "SSS 3"
  createdAt DateTime @default(now())

  school                School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  arms                  Arm[]
  students              Student[]
  scores                Score[]
  reportComments        ReportCardComment[]
  attendance            Attendance[]
  dailyAttendance       DailyAttendance[]
  subjectAssignments    SubjectAssignment[]
  scoreSubmissions      ScoreSubmission[]
  classReportStatuses   ClassReportStatus[]

}

model Arm {
  id             String  @id @default(uuid())
  schoolId       String
  classId        String
  name           String // E.g., "A", "B", "Gold"
  classTeacherId String?

  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class              Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher       User?               @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  students           Student[]
  scores             Score[]
  reportComments     ReportCardComment[]
  attendance         Attendance[]
  dailyAttendance    DailyAttendance[]
  subjectAssignments SubjectAssignment[]
  scoreSubmissions   ScoreSubmission[]
  classReportStatuses ClassReportStatus[]
}

model Student {
  id              String   @id @default(uuid())
  schoolId        String
  firstName       String
  lastName        String
  middleName      String?
  admissionNumber String // Unique within the school
  gender          String // MALE, FEMALE
  dateOfBirth     String?
  passportPhoto   String? // Base64 string or image link
  classId         String
  armId           String
  status          String   @default("ACTIVE") // ACTIVE, GRADUATED, TRANSFERRED, WITHDRAWN, SUSPENDED, ARCHIVED
  feesPaid        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school         School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class          Class               @relation(fields: [classId], references: [id])
  arm            Arm                 @relation(fields: [armId], references: [id])
  scores         Score[]
  reportComments ReportCardComment[]
  attendance     Attendance[]
  dailyAttendance DailyAttendance[]
  parentId       String?
  parent         Parent?             @relation(fields: [parentId], references: [id], onDelete: SetNull)
  user           User?               @relation("StudentUser")

  @@unique([schoolId, admissionNumber])
}
model Subject {
  id           String   @id @default(uuid())
  schoolId     String
  name         String // E.g., "Mathematics"
  code         String // E.g., "MTH"
  category     String   @default("COMPULSORY") // COMPULSORY, ELECTIVE
  color        String   @default("blue") // Curated display color code
  restrictions String   @default("") // JSON string blocklist/matrix for periods/days
  createdAt    DateTime @default(now())

  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  scores             Score[]
  subjectAssignments SubjectAssignment[]
  scoreSubmissions   ScoreSubmission[]
}

model SubjectAssignment {
  id        String   @id @default(uuid())
  schoolId  String
  subjectId String
  classId   String
  armId     String
  teacherId String
  termId    String
  createdAt DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  arm     Arm     @relation(fields: [armId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([schoolId, subjectId, classId, armId, termId, teacherId])
}

model Score {
  id         String   @id @default(uuid())
  schoolId   String
  studentId  String
  subjectId  String
  termId     String
  classId    String
  armId      String
  ca1        Float? // E.g., Max 15
  ca2        Float? // E.g., Max 15
  assignment Float? // E.g., Max 10
  exam       Float? // E.g., Max 60
  total      Float? // (ca1 + ca2 + assignment + exam)
  grade      String?
  remarks    String?
  teacherId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  arm     Arm     @relation(fields: [armId], references: [id], onDelete: Cascade)
  teacher User?   @relation("ScoreTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([schoolId, studentId, subjectId, termId])
}

model GradingRule {
  id             String   @id @default(uuid())
  schoolId       String
  minScore       Float
  maxScore       Float
  grade          String // E.g., "A1", "C4", "F9"
  interpretation String // E.g., "Excellent", "Credit", "Fail"
  createdAt      DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Attendance {
  id          String   @id @default(uuid())
  schoolId    String
  studentId   String
  termId      String
  classId     String
  armId       String
  daysPresent Int      @default(0)
  daysAbsent  Int      @default(0)
  createdAt   DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  arm     Arm     @relation(fields: [armId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, termId])
}

model DailyAttendance {
  id             String   @id @default(uuid())
  schoolId       String
  studentId      String
  classId        String
  armId          String
  termId         String
  attendanceDate String // YYYY-MM-DD DATE string
  status         String   @default("PRESENT") // PRESENT, ABSENT
  markedBy       String?
  createdAt      DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  arm     Arm     @relation(fields: [armId], references: [id], onDelete: Cascade)

  @@unique([studentId, attendanceDate])
}

model ReportCardComment {
  id                 String   @id @default(uuid())
  schoolId           String
  studentId          String
  termId             String
  classId            String
  armId              String
  teacherComment     String?
  headTeacherComment String?
  isAIGenerated      Boolean  @default(false)
  published          Boolean  @default(false)
  createdAt          DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  arm     Arm     @relation(fields: [armId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, termId])
}

model ScoreSubmission {
  id        String   @id @default(uuid())
  schoolId  String
  subjectId String
  classId   String
  armId     String
  termId    String
  teacherId String // Sender (Subject Teacher)
  status    String   @default("PENDING") // DRAFT, PENDING, APPROVED, REJECTED
  sentAt    DateTime @default(now())
  payload   String // JSON string of scores rows

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  arm           Arm            @relation(fields: [armId], references: [id], onDelete: Cascade)
  teacher       User           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  term          Term           @relation(fields: [termId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([schoolId, subjectId, classId, armId, termId])
}

model Notification {
  id           String   @id @default(uuid())
  schoolId     String
  userId       String // Receiver (e.g. Class Teacher)
  message      String
  isRead       Boolean  @default(false)
  submissionId String?
  createdAt    DateTime @default(now())

  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission ScoreSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Parent {
  id           String   @id @default(uuid())
  schoolId     String
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  address      String?
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students Student[]
  user     User?     @relation("ParentUser")
}



model Event {
  id          String   @id @default(uuid())
  schoolId    String
  title       String
  description String?
  date        String // YYYY-MM-DD
  time        String // E.g., "08:00 - 10:00"
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(uuid())
  schoolId  String
  title     String
  content   String
  date      String // YYYY-MM-DD
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Message {
  id             String             @id @default(uuid())
  schoolId       String
  senderId       String?
  title          String
  body           String
  messageType    String             @default("ANNOUNCEMENT") // ANNOUNCEMENT, DIRECT, AUTOMATED
  targetAudience String             @default("ALL") // ALL, TEACHERS, STUDENTS, PARENTS, CLASS, ARM
  priority       String             @default("NORMAL") // NORMAL, HIGH, URGENT
  isPinned       Boolean            @default(false)
  scheduledFor   String?            // YYYY-MM-DD
  expiresAt      String?            // YYYY-MM-DD
  classId        String?
  armId          String?
  createdAt      DateTime           @default(now())

  school         School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender         User?              @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipients     MessageRecipient[]
}

model MessageRecipient {
  id          String    @id @default(uuid())
  messageId   String
  recipientId String
  isRead      Boolean   @default(false)
  readAt      DateTime?

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient User    @relation("MessageRecipientUser", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([messageId, recipientId])
}

model Payment {
  id            String   @id @default(uuid())
  schoolId      String
  amount        Float
  paymentDate   DateTime @default(now())
  paymentMethod String   // Bank Transfer, Cash, Card
  status        String   @default("pending") // paid, pending, overdue, failed

  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id           String   @id @default(uuid())
  schoolId     String
  activityType String   // Login, Report Generation, Attendance Marked, etc.
  createdAt    DateTime @default(now())

  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model ClassReportStatus {
  id        String   @id @default(uuid())
  schoolId  String
  classId   String
  armId     String
  termId    String
  status    String   @default("DRAFT") // DRAFT, AWAITING_APPROVAL, APPROVED, REJECTED
  feedback  String?  // Feedback if returned for correction
  updatedAt DateTime @updatedAt

  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  arm       Arm      @relation(fields: [armId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, armId, termId])
}

model Lead {
  id                      String            @id @default(uuid())
  schoolName              String
  schoolType              String?           // PRIMARY, SECONDARY, COMBINED
  ownershipType           String?           // PRIVATE, PUBLIC
  contactName             String?
  position                String?           // PROPRIETOR, PRINCIPAL, VICE_PRINCIPAL, TEACHER, ADMINISTRATOR
  email                   String            @unique
  phone                   String?
  studentCount            Int?
  teacherCount            Int?
  classCount              Int?
  currentResultMethod     String?
  currentAttendanceMethod String?
  biggestChallenge        String?
  interestedFeatures      String?           // Comma-separated list or JSON array string of features
  leadStatus              String            @default("NEW") // NEW, CONTACTED, DEMO_SENT, TESTING, FEEDBACK_RECEIVED, INTERESTED, PILOT_SCHOOL, CUSTOMER, NOT_INTERESTED
  demoSchoolId            String?           // Reference to created demo school
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @default(now()) @updatedAt
  
  emailLogs               EmailLog[]
  feedback                Feedback?
  testerActivity          TesterActivity?
}

model EmailLog {
  id         String   @id @default(uuid())
  leadId     String
  recipient  String
  subject    String
  body       String
  sentAt     DateTime @default(now())
  
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model TesterActivity {
  id                         String    @id @default(uuid())
  userId                     String    @unique // Auth User ID generated for demo access
  leadId                     String    @unique
  lastLogin                  DateTime?
  loginCount                 Int       @default(0)
  timeSpent                  Int       @default(0) // Cumulative seconds active
  featuresVisited            String    @default("") // Comma-separated feature codes
  reportCardsGeneratedCount  Int       @default(0)
  attendanceSessionsCount    Int       @default(0)
  resultsViewedCount         Int       @default(0)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  
  lead                       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Feedback {
  id                 String   @id @default(uuid())
  leadId             String   @unique
  easeOfUse          Int      // Rating 1-5
  design             Int      // Rating 1-5
  usefulness         Int      // Rating 1-5
  mostUsefulFeature  String
  confusingFeature   String
  suggestions        String
  wouldUseInSchool   String   // YES, MAYBE, NO
  wouldPay           String   // YES, MAYBE, NO
  additionalComments String?
  createdAt          DateTime @default(now())
  
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}


